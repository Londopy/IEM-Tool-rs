{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IEM Tool",
  "version": "1.0.0",
  "identifier": "com.mylittleprimordia.iemtool",
  "build": {
    "frontendDist": "../../app-files"
  },
  "app": {
    "windows": [
      {
        "title": "IEM Tool",
        "width": 1400,
        "height": 900,
        "minWidth": 360,
        "minHeight": 360,
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
