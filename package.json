{
  "name": "iem-tool-rs",
  "version": "1.3.0",
  "description": "🎧 IEM-Tool-rs - Parametric EQ & Frequency Response Analyzer (Rust core)",
  "main": "main.js",
  "author": "🍄 MyLittlePrimordia",
  "license": "MIT",

  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish never",
    "dist-win": "electron-builder --win --publish never",
    "dist-mac": "electron-builder --mac --publish never",
    "dist-linux": "electron-builder --linux --publish never"
  },

  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },

  "build": {
    "appId": "com.londopy.iem-tool-rs",
    "productName": "IEM-Tool-rs",

    "asar": false,

    "files": [
      "**/*"
    ],

    "extraResources": [
      {
        "from": "app-files",
        "to": "app-files"
      }
    ],

    "directories": {
      "output": "dist"
    },

    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "IEM-Tool-rs"
    },

    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "icon.icns",
      "category": "public.app-category.utilities"
    },

    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "icon.png",
      "category": "Utility"
    }
  }
}